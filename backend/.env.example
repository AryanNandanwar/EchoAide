# WebSocket Configuration
WEBSOCKET_PORT=8080
WEBSOCKET_CORS_ORIGIN=*

# Soniox AI Configuration
SONIOX_API_KEY=your_soniox_api_key_here
SONIOX_MODEL=stt-rt-preview
SONIOX_AUDIO_FORMAT=pcm_s16le
SONIOX_SAMPLE_RATE=16000
SONIOX_NUM_CHANNELS=1
SONIOX_LANGUAGE_HINTS=en
SONIOX_ENABLE_SPEAKER_DIARIZATION=false
SONIOX_ENABLE_LANGUAGE_IDENTIFICATION=true
SONIOX_ENABLE_ENDPOINT_DETECTION=true
SONIOX_MAX_ENDPOINT_DELAY_MS=2000

# Soniox Translation Configuration
SONIOX_ENABLE_TRANSLATION=false
SONIOX_TRANSLATION_TYPE=one_way
SONIOX_TRANSLATION_TARGET_LANGUAGE=en
SONIOX_TRANSLATION_LANGUAGE_A=en
SONIOX_TRANSLATION_LANGUAGE_B=es

# AWS Configuration
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# Bedrock Configuration
BEDROCK_MODEL_ID=apac.anthropic.claude-3-5-sonnet-20241022-v2:0

# Bedrock Rate Limiting Configuration
BEDROCK_MIN_CALL_INTERVAL=6000
BEDROCK_MAX_RETRIES=5
BEDROCK_BASE_DELAY=2000
BEDROCK_MAX_DELAY=20000
BEDROCK_CACHE_TTL=300000
BEDROCK_BATCH_TIMEOUT=2000
BEDROCK_CONTENT_CHANGE_THRESHOLD=0.3

# Database Configuration (existing)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=doctorscribe
DATABASE_USER=postgres
DATABASE_PASSWORD=your_password

# JWT Configuration (existing)
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=24h
